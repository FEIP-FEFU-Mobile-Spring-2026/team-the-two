<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/cart_item_bg">

    <!-- Список товаров -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/cartRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Контейнер для пустой корзины, в макете его нет -->
    <LinearLayout
        android:id="@+id/emptyCartContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <ImageView
            android:layout_width="@dimen/cart_image_size"
            android:layout_height="@dimen/cart_image_size"
            android:src="@android:drawable/ic_menu_delete"
            app:tint="@color/cart_empty_text" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Корзина пуста"
            android:textSize="@dimen/cart_empty_text_size"
            android:textColor="@color/cart_empty_text" />

    </LinearLayout>

    <!-- Разделитель -->
    <View
        android:layout_width="match_parent"
        android:layout_height="11dp"
        android:background="@color/cart_divider" />

    <!-- Контейнер формы -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="20dp">

        <!-- Имя пользователя, в макете есть, кода в документе не было. Если не надо, удалите -->
        <EditText
            android:id="@+id/userName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="12dp"
            android:paddingVertical="17dp"
            android:hint="Имя"
            android:textSize="17sp"
            android:inputType="text"
            android:textColor="@android:color/darker_gray"
            android:background="@color/cart_comment_bg"/>

        <!-- Email пользователя -->
        <EditText
            android:id="@+id/userEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:paddingHorizontal="@dimen/cart_item_padding"
            android:paddingVertical="@dimen/cart_item_padding"
            android:hint="Почта"
            android:textSize="@dimen/cart_product_price_size"
            android:inputType="textEmailAddress"
            android:textColor="@color/cart_empty_text"
            android:background="@color/cart_comment_bg"/>

        <!-- Поле комментария к заказу -->
        <EditText
            android:id="@+id/orderComment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="@dimen/cart_comment_min_height"
            android:layout_marginTop="@dimen/cart_comment_margin"
            android:paddingHorizontal="@dimen/cart_comment_padding"
            android:paddingVertical="@dimen/cart_comment_padding"
            android:gravity="top|start"
            android:hint="Комментарий к заказу"
            android:textSize="17sp"
            android:inputType="textMultiLine"
            android:textColor="@android:color/darker_gray"
            android:background="@color/cart_comment_bg"/>

    </LinearLayout>

    <!-- Контейнер итогов -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@color/cart_comment_bg">

        <!-- Итого и цена -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Итого:"
                android:textSize="@dimen/cart_total_price_size"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/totalPriceText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 ₽"
                android:textColor="@color/cart_total_price_color"
                android:textSize="@dimen/cart_total_price_size"
                android:textStyle="bold"/>

        </LinearLayout>

        <!-- Кнопка оформить -->
        <Button
            android:id="@+id/checkoutButton"
            android:layout_width="match_parent"
            android:layout_height="@dimen/cart_button_height"
            android:layout_weight="1"
            android:layout_marginTop="12dp"
            android:backgroundTint="@color/cart_checkout_button_bg"
            android:text="Оформить"
            android:textSize="17sp"/>

        <!-- Кнопка Очистить, нет в макете, есть в документе и реализация работы кнопки в прошлых файлах -->
        <Button
            android:id="@+id/clearCartButton"
            android:layout_width="match_parent"
            android:layout_height="@dimen/cart_button_height"
            android:layout_weight="1"
            android:layout_marginTop="12dp"
            android:backgroundTint="@color/cart_clear_button_bg"
            android:text="Очистить корзину"
            android:textSize="17sp"/>


    </LinearLayout>

</LinearLayout>

