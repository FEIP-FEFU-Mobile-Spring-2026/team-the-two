<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Список товаров -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/cartRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Контейнер для пустой корзины, в макете его нет -->
    <LinearLayout
        android:id="@+id/emptyCartContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <ImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@android:drawable/ic_menu_delete"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Корзина пуста"
            android:textSize="20sp"
            android:textColor="@android:color/darker_gray" />

    </LinearLayout>

    <!-- Разделитель -->
    <View
        android:layout_width="match_parent"
        android:layout_height="11dp"
        android:background="@android:color/darker_gray" />

    <!-- Контейнер формы -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="20dp">

        <!-- Имя пользователя, в макете есть, кода в документе не было. Если не надо, удалите -->
        <EditText
            android:id="@+id/userName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="12dp"
            android:paddingVertical="17dp"
            android:hint="Имя"
            android:textSize="17sp"
            android:inputType="text"
            android:textColor="@android:color/darker_gray"
            android:background="@android:color/darker_gray"/>

        <!-- Email пользователя -->
        <EditText
            android:id="@+id/userEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:paddingHorizontal="12dp"
            android:paddingVertical="17dp"
            android:hint="Почта"
            android:textSize="17sp"
            android:inputType="textEmailAddress"
            android:textColor="@android:color/darker_gray"
            android:background="@android:color/darker_gray"/>

        <!-- Поле комментария к заказу -->
        <EditText
            android:id="@+id/orderComment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="104dp"
            android:layout_marginTop="12dp"
            android:paddingHorizontal="12dp"
            android:paddingVertical="17dp"
            android:gravity="top|start"
            android:hint="Комментарий к заказу"
            android:textSize="17sp"
            android:inputType="textMultiLine"
            android:textColor="@android:color/darker_gray"
            android:background="@android:color/darker_gray"/>

    </LinearLayout>

    <!-- Контейнер итогов -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@android:color/darker_gray">

        <!-- Итого и цена -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Итого:"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/totalPriceText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 ₽"
                android:textSize="20sp"
                android:textStyle="bold"/>

        </LinearLayout>

        <!-- Кнопка оформить -->
        <Button
            android:id="@+id/checkoutButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginTop="12dp"
            android:text="Оформить"
            android:textSize="17sp"/>

        <!-- Кнопка Очистить, нет в макете, есть в документе и реализация работы кнопки в прошлых файлах -->
        <Button
            android:id="@+id/clearCartButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginTop="12dp"
            android:text="Очистить корзину"
            android:textSize="17sp"/>


    </LinearLayout>

</LinearLayout>

