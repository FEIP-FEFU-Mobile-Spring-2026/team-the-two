<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="@color/cart_item_bg">

    <ImageView
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@android:drawable/ic_dialog_info"
        app:tint="@color/cart_checkout_button_bg" />   <!-- ← заменил android:tint на app:tint -->

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Заказ успешно оформлен"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/cart_total_price_color"
        android:layout_marginTop="24dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Подтверждение и чек отправлены на вашу почту"
        android:textSize="14sp"
        android:textColor="@color/cart_empty_text"
        android:layout_marginTop="8dp"
        android:gravity="center" />

    <Button
        android:id="@+id/backToHomeButton"
        android:layout_width="match_parent"
        android:layout_height="@dimen/cart_button_height"
        android:backgroundTint="@color/cart_checkout_button_bg"
        android:text="Вернуться на главную"
        android:layout_marginTop="32dp" />

</LinearLayout>